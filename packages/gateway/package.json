{
  "name": "@anima/gateway",
  "version": "0.1.0",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "predev": "lsof -ti:30086 | xargs kill -9 2>/dev/null || true",
    "dev": "bun run --watch src/start.ts",
    "start": "bun run src/start.ts",
    "build": "bun build src/start.ts --outdir dist --target bun",
    "test": "bun test",
    "typecheck": "tsc --noEmit -p ../../tsconfig.json"
  },
  "dependencies": {
    "@anima/ext-audiobooks": "workspace:*",
    "@anima/ext-chat": "workspace:*",
    "@anima/ext-control": "workspace:*",
    "@anima/ext-editor": "workspace:*",
    "@anima/ext-imessage": "workspace:*",
    "@anima/ext-presenter": "workspace:*",
    "@anima/memory": "workspace:*",
    "@anima/shared": "workspace:*",
    "@anima/ui": "workspace:*",
    "@anima/voice": "workspace:*",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "bun-plugin-tailwind": "0.1.2",
    "tailwindcss": "^4.0.0"
  }
}
