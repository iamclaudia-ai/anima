    "@anima/ext-editor": "workspace:*",
    "@anima/ext-imessage": "workspace:*",
    "@anima/ext-presenter": "workspace:*",
    "@anima/ext-scheduler": "workspace:*",
    "@anima/memory": "workspace:*",
    "@anima/shared": "workspace:*",
    "@anima/ui": "workspace:*",
    "@anima/voice": "workspace:*",
    "react-markdown": "catalog:",
    "remark-gfm": "4.0.1",
    "zod": "catalog:",
    "zod-to-json-schema": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/typography": "catalog:",
    "bun-plugin-tailwind": "catalog:",
    "tailwindcss": "catalog:"
  }
