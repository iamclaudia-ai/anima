{
  "name": "@anima/gateway",
  "version": "0.1.0",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "predev": "lsof -ti:30086 | xargs kill -9 2>/dev/null || true",
    "dev": "bun run src/start.ts",
    "start": "bun run src/start.ts",
    "build": "bun build src/start.ts --outdir dist --target bun",
    "test": "bun test",
    "typecheck": "tsc --noEmit -p ../../tsconfig.json"
  },
  "dependencies": {
    "@anima/ext-audiobooks": "workspace:*",
