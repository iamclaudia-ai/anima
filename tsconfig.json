{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "baseUrl": ".",
    "paths": {
      "@anima/shared": ["./packages/shared/src/index.ts"],
      "@anima/gateway": ["./packages/gateway/src/index.ts"],
      "@anima/ui": ["./packages/ui/src/index.ts"],
      "@anima/*": [
        "./packages/*/src/index.ts",
        "./clients/*/src/index.ts",
        "./extensions/*/src/index.ts"
      ]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx",
    "clients/*/src/**/*.ts",
    "clients/*/src/**/*.tsx",
    "hooks/**/*.ts",
    "extensions/*/src/**/*.ts",
    "extensions/*/src/**/*.tsx"
  ],
  "exclude": ["node_modules", "**/dist/**", "clients/dominatrix/**"]
}
