{
  "name": "@anima/vscode",
  "displayName": "Anima",
  "version": "0.1.0",
  "description": "Anima platform for Claudia in VS Code",
  "categories": [
    "AI",
    "Chat",
    "Programming Languages"
  ],
  "keywords": [
    "ai",
    "anima",
    "assistant",
    "claude",
    "coding"
  ],
  "publisher": "iamclaudia-ai",
  "main": "./dist/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsc -p ./ && bun run build-webview.ts",
    "build:webview": "bun run build-webview.ts",
    "compile": "tsc -p ./",
    "typecheck": "tsc -p ./ --noEmit",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "@anima/ui": "workspace:*",
    "react": "catalog:",
    "react-dom": "catalog:",
    "ws": "^8.x"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.x",
    "@typescript-eslint/parser": "^6.x",
    "bun-plugin-tailwind": "catalog:",
    "eslint": "^8.x",
    "tailwindcss": "catalog:",
    "typescript": "catalog:"
  },
  "contributes": {
    "commands": [
      {
        "command": "anima.openChat",
        "title": "Open Claudia Chat",
        "category": "Anima",
        "icon": {
          "light": "resources/icon-light.svg",
          "dark": "resources/icon-dark.svg"
        }
      },
      {
        "command": "anima.sendSelection",
        "title": "Send Selection to Claudia",
        "category": "Anima"
      },
      {
        "command": "anima.explainCode",
        "title": "Explain This Code",
        "category": "Anima"
      },
      {
        "command": "anima.fixCode",
        "title": "Fix This Code",
        "category": "Anima"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "anima.openChat",
          "group": "navigation@-100"
        }
      ],
      "editor/context": [
        {
          "command": "anima.sendSelection",
          "when": "editorHasSelection",
          "group": "anima@1"
        },
        {
          "command": "anima.explainCode",
          "when": "editorHasSelection",
          "group": "anima@2"
        },
        {
          "command": "anima.fixCode",
          "when": "editorHasSelection",
          "group": "anima@3"
        }
      ]
    },
    "configuration": {
      "title": "Anima",
      "properties": {
        "anima.gatewayUrl": {
          "type": "string",
          "default": "ws://localhost:30086/ws",
          "description": "Anima Gateway WebSocket URL"
        },
        "anima.includeFileContext": {
          "type": "boolean",
          "default": true,
          "description": "Automatically include current file context in messages"
        },
        "anima.openOnStartup": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open the Anima panel when VS Code starts (prefer .vscode/settings.local.json)"
        }
      }
    },
    "keybindings": [
      {
        "command": "anima.openChat",
        "key": "ctrl+shift+c",
        "mac": "cmd+shift+c"
      }
    ]
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  }
}
