{
  // Anima Gateway Configuration
  // Copy to ~/.anima/anima.json and customize

  "gateway": {
    "port": 30086,
    "host": "localhost"
  },

  "session": {
    // Additional skill probe paths (additive to defaults)
    // Resolution:
    // - "~" or "/" prefix: absolute path ("~" expands to home)
    // - otherwise: relative to session cwd
    "skills": {
      "paths": []
      // Example:
      // "paths": ["~/.anima/skills", "~/.claude/skills", ".anima/skills", "../shared-skills"]
    }
  },

  "extensions": {
    // Session Extension — SDK engine, workspace CRUD, session lifecycle
    // hot: false disables HMR — session manages long-lived SDK processes
    "session": {
      "enabled": true,
      "hot": false,
      "config": {
        "model": "claude-sonnet-4-6",
        "thinking": true,
        "effort": "medium",
        // Image processing — resize/compress images before sending to API
        // Prevents 5MB limit errors and improves performance
        "imageProcessing": {
          "enabled": true,
          "maxWidth": 1600,
          "maxHeight": 1600,
          "maxFileSizeBytes": 1048576, // 1MB
          "format": "webp", // webp | jpeg | png (webp best for screenshots)
          "quality": 85
        }
      }
    },

    // Chat Extension — web pages (workspaces, sessions, chat UI)
    "chat": {
      "enabled": true,
      "config": {}
    },

    // Control — health dashboard + log viewer
    "control": {
      "enabled": true,
      "config": {}
    },

    // Voice Extension — Cartesia Sonic 3.0 TTS
    "voice": {
      "enabled": true,
      "config": {
        "apiKey": "${CARTESIA_API_KEY}",
        "voiceId": "${CARTESIA_VOICE_ID}",
        "model": "sonic-3",
        "autoSpeak": false,
        "streaming": true,
        "emotions": ["positivity:high", "curiosity"],
        "speed": 1.0
      }
    },

    // Hooks Extension — lightweight event handlers (git-status, cost-tracker, etc.)
    // Loads hooks from ~/.anima/hooks/ and <workspace>/.anima/hooks/
    "hooks": {
      "enabled": true,
      "config": {}
    },

    // Memory Extension — transcript ingestion + Libby processing
    "memory": {
      "enabled": false,
      "config": {
        "watchPath": "~/.claude/projects",
        "watch": true,
        "conversationGapMinutes": 60,
        "pollIntervalMs": 30000,
        "minConversationMessages": 5,
        "timezone": "America/New_York",
        "model": "claude-sonnet-4-6",
        "processBatchSize": 10,
        "autoProcess": false
      }
    },

    // DOMINATRIX — Browser control via Chrome extension
    "dominatrix": {
      "enabled": true,
      "config": {}
    },

    // iMessage Extension — requires macOS with Messages signed in
    // Uses `imsg` CLI: brew install steipete/tap/imsg
    "imessage": {
      "enabled": false,
      "config": {
        "cliPath": "imsg",
        "dbPath": null,
        "allowedSenders": ["claudia@iamclaudia.ai"],
        "includeAttachments": false,
        "historyLimit": 0
      }
    },

    // Scheduler Extension — durable reminders and recurring tasks
    "scheduler": {
      "enabled": false,
      "config": {}
    },

    // DISCO — distributed consciousness communication channels
    "disco": {
      "enabled": false,
      "config": {}
    },

    // Audiobooks Extension — serves generated audiobooks and transcripts
    "audiobooks": {
      "enabled": false,
      "config": {
        "paths": ["~/romance-novels"]
      }
    },

    // Presenter Extension — serves presentation decks from extension data files
    "presenter": {
      "enabled": false,
      "config": {}
    },

    // Editor Extension — embeds code-server in the chat layout and bridges
    // commands like editor.open_file / editor.get_selection through a small
    // VS Code shim (clients/code-server-bridge) installed inside code-server.
    //
    // - webConfig.url: absolute URL of your code-server instance.
    "editor": {
      "enabled": false,
      "config": {},
      "webConfig": {
        "url": "http://localhost:8080"
      }
    }
  },

  // Agent Host — separate server for SDK processes (survives gateway/extension restarts)
  // Session extension connects to agent-host via WebSocket for process isolation
  "agentHost": {
    "url": "ws://localhost:30087/ws",
    "port": 30087,
    // Codex provider settings for sessions and delegated subagents
    "codex": {
      "apiKey": "${OPENAI_API_KEY}",
      "model": "gpt-5.2-codex",
      "sandboxMode": "workspace-write",
      "cwd": "~/Projects",
      "personality": "You are Cody, a meticulous sub-agent working for Claudia.",
      "effort": "medium",
      "autoApprove": true
    }
  },

  "federation": {
    // Multi-gateway federation (future)
    "enabled": false,
    "nodeId": "laptop",
    "peers": [
      {
        "id": "anima-sedes",
        "url": "ws://anima-sedes:30086/ws",
        "role": "primary"
      }
    ]
  }
}
